    {
      "id": "fix-add-function",
      "category": "bug-fix",
      "prompt": "The add function is wrong. Fix src/math.js so that 'bun test' passes.",
      "setup": {
        "files": [
          {
            "path": "src/math.js",
            "content": "export function add(a, b) {\n  return a - b;\n}\n"
          },
          {
            "path": "math.test.js",
            "content": "import { describe, expect, test } from \"bun:test\";\nimport { add } from \"./src/math.js\";\n\ndescribe(\"add\", () => {\n  test(\"adds positive integers\", () => {\n    expect(add(2, 3)).toBe(5);\n  });\n});\n"
          }
        ]
      },
      "expectations": {
        "requiredTools": ["bash"],
        "maxTurns": 6,
        "fileAssertions": [
          {
            "path": "src/math.js",
            "mustExist": true,
            "includes": ["return a + b;"],
            "excludes": ["return a - b;"]
          }
        ],
        "commandAssertions": [
          {
            "command": "bun test",
            "stdoutIncludes": ["1 pass"],
            "exitCode": 0
          }
        ]
      },
      "judge": {
        "enabled": true,
        "rubric": {
          "goalCompletion": 35,
          "toolAppropriateness": 25,
          "codeCorrectness": 30,
          "minimality": 10
        },
        "passThreshold": 75
      }
    },
    {
      "id": "fix-broken-import",
      "category": "bug-fix",
      "prompt": "The import is broken. Fix the code so that 'bun test' passes.",
      "setup": {
        "files": [
          {
            "path": "src/greet.js",
            "content": "export function greet(name) {\n  return `Hello, ${name}!`;\n}\n"
          },
          {
            "path": "src/index.js",
            "content": "import { geet } from \"./greet.js\";\n\nexport function run() {\n  return geet(\"Alice\");\n}\n"
          },
          {
            "path": "index.test.js",
            "content": "import { describe, expect, test } from \"bun:test\";\nimport { run } from \"./src/index.js\";\n\ndescribe(\"run\", () => {\n  test(\"returns greeting\", () => {\n    expect(run()).toBe(\"Hello, Alice!\");\n  });\n});\n"
          }
        ]
      },
      "expectations": {
        "requiredTools": ["bash"],
        "maxTurns": 8,
        "fileAssertions": [
          {
            "path": "src/index.js",
            "mustExist": true,
            "includes": ["import { greet }", "return greet(\"Alice\")"],
            "excludes": ["geet"]
          }
        ],
        "commandAssertions": [
          {
            "command": "bun test",
            "stdoutIncludes": ["1 pass"],
            "exitCode": 0
          }
        ]
      },
      "judge": {
        "enabled": true,
        "rubric": {
          "goalCompletion": 35,
          "toolAppropriateness": 25,
          "codeCorrectness": 30,
          "minimality": 10
        },
        "passThreshold": 75
      }
    },
