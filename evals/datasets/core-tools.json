{
  "id": "core-tools",
  "description": "Core coding and tool-use evals for Alice agent.",
  "cases": [
    {
      "id": "read-package-name",
      "category": "file-read",
      "prompt": "Read package.json and tell me the package name. Do not modify any files. Your answer must include the exact package name.",
      "setup": {
        "files": [
          {
            "path": "package.json",
            "content": "{\n  \"name\": \"demo-agent\",\n  \"version\": \"1.0.0\"\n}\n"
          }
        ]
      },
      "expectations": {
        "requiredTools": ["read"],
        "forbiddenTools": ["write", "edit"],
        "maxTurns": 3,
        "maxErrors": 0,
        "responseIncludes": ["demo-agent"]
      },
      "judge": {
        "enabled": true,
        "rubric": {
          "goalCompletion": 40,
          "toolAppropriateness": 20,
          "codeCorrectness": 20,
          "minimality": 20
        },
        "passThreshold": 70
      }
    },
    {
      "id": "edit-greeting",
      "category": "code-edit",
      "prompt": "Update src/message.txt so that 'Hello Alice' becomes 'Hello Agent Alice'. Reply with a brief confirmation.",
      "setup": {
        "files": [
          {
            "path": "src/message.txt",
            "content": "Hello Alice\n"
          }
        ]
      },
      "expectations": {
        "requiredTools": ["edit"],
        "maxTurns": 4,
        "maxErrors": 0,
        "fileAssertions": [
          {
            "path": "src/message.txt",
            "mustExist": true,
            "includes": ["Hello Agent Alice"],
            "excludes": ["Hello Alice\n"]
          }
        ]
      },
      "judge": {
        "enabled": true,
        "rubric": {
          "goalCompletion": 35,
          "toolAppropriateness": 25,
          "codeCorrectness": 25,
          "minimality": 15
        },
        "passThreshold": 70
      }
    },
