{
  "name": "alice-agent",
  "version": "0.1.0",
  "description": "A universal AI Agent CLI tool built with TypeScript + Bun",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "alice": "src/cli.ts"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "dev": "bun run --watch src/cli.ts",
    "serve": "bun run src/cli.ts serve",
    "serve:dev": "bun run --watch src/cli.ts serve",
    "test": "bun test",
    "eval": "bun run src/eval-cli.ts",
    "eval:core": "bun run src/eval-cli.ts --dataset core-tools",
    "eval:json": "bun run src/eval-cli.ts --dataset core-tools --json",
    "build": "bun build src/cli.ts --compile --outfile alice",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
